# Copy to Vercel Environment Variables (or rename to .env.local for local dev)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe（サーバー）— Webhook で is_pro を更新
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Checkout Session 作成用（Payment Link ではなく、その商品の Price ID: price_...）
# 未設定の場合は NEXT_PUBLIC_STRIPE_PRO_CHECKOUT_URL の Payment Link から Price を解決します
STRIPE_PRO_PRICE_ID=
# Supabase service role（RLS 回避・webhook のみで使用）
SUPABASE_SERVICE_ROLE_KEY=

# 任意：既存 Payment Link から Price を解決するフォールバック用
NEXT_PUBLIC_STRIPE_PRO_CHECKOUT_URL=
